generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  clerkId   String   @unique // Links to Clerk authentication
  email     String   @unique
  role      Role     @default(CLIENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invitations Invitation[]
}

enum Role {
  ADMIN
  CLIENT
}

model Invitation {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  status      Status   @default(DRAFT)
  
  // Settings for the entire invitation (e.g. global fonts, primary color)
  settingsJSON Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Optional relation if it was cloned from a template
  templateId  String?
  template    Template? @relation(fields: [templateId], references: [id])

  sections    Section[]
}

enum Status {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Section {
  id            String   @id @default(uuid())
  type          String   // e.g. "hero", "gallery", "timeline"
  order         Int      // Controls the vertical order on the page
  isVisible     Boolean  @default(true)
  
  // The actual structured data (content) for this block
  contentJSON   Json     
  
  // Animation settings for framer-motion (delay, type, etc)
  animationSettingsJSON Json? 

  invitationId  String
  invitation    Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Template {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Int      @default(0) // 0 means free
  type        TemplateType @default(FREE)
  status      Status   @default(DRAFT)
  
  // Default blocks that get copied when a user uses this template
  defaultSectionsJSON Json

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invitations Invitation[]
}

enum TemplateType {
  FREE
  PREMIUM
}
