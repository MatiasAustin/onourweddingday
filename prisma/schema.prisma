generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  EDITOR
  CUSTOMER
}

model User {
  id        String   @id @default(cuid()) // Matches Clerk ID if synced
  clerkId   String   @unique
  email     String   @unique
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invitations Invitation[]
  media       Media[]
}

model Template {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  coverImage     String?
  previewVideo   String?
  style          String?  // e.g., "rustic", "modern", "elegant"
  colorTheme     String?  // JSON or string identifier
  isPremium      Boolean  @default(false)
  structureJSON  Json     // Default sections for this template
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  invitations    Invitation[]
}

model Invitation {
  id           String   @id @default(cuid())
  userId       String
  templateId   String
  slug         String   @unique
  title        String
  status       String   @default("DRAFT") // DRAFT, PUBLISHED, ARCHIVED
  settingsJSON Json?    // Global settings like fonts, colors, custom domain
  domain       String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User       @relation(fields: [userId], references: [id])
  template     Template   @relation(fields: [templateId], references: [id])
  sections     Section[]
}

model Section {
  id                    String   @id @default(cuid())
  invitationId          String
  type                  String   // e.g., "hero", "gallery", "timeline", "rsvp"
  order                 Int
  isVisible             Boolean  @default(true)
  contentJSON           Json     // The actual content (text, image URLs)
  animationSettingsJSON Json?    // Animation config (entrance, parallax)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  invitation            Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
}

model Media {
  id        String   @id @default(cuid())
  url       String
  type      String   // "IMAGE", "VIDEO", "AUDIO", "DOCUMENT"
  userId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}
